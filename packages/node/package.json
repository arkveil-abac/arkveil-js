  },
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "arkveil": "workspace:*"
  }
